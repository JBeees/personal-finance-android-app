<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FinanceApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bg_primary</item>
        <item name="colorPrimaryVariant">@color/bg_secondary</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_white</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.FinanceApp.Dialog</item>
    </style>

    <style name="Theme.FinanceApp.Splash" parent="Theme.FinanceApp">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <style name="ThemeOverlay.FinanceApp.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:background">@color/bg_card</item>
        <item name="colorPrimary">@color/accent_white</item>
    </style>

    <!-- Text Styles -->
    <style name="TextStyle.Display" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextStyle.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Button Styles -->
    <style name="ButtonStyle.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent_white</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <style name="ButtonStyle.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/surface_stroke</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <!-- Card Style -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/surface_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Bottom Sheet -->
    <style name="BottomSheetStyle" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="android:background">@color/bg_card</item>
        <item name="bottomSheetStyle">@style/Widget.FinanceApp.BottomSheet</item>
    </style>

    <style name="Widget.FinanceApp.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/bg_card</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.FinanceApp.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.FinanceApp.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
    </style>

</resources>
