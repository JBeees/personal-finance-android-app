<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="24dp"
    android:layout_margin="24dp">

    <TextView
        android:id="@+id/tvDebtDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TAMBAH HUTANG"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="20dp" />

    <!-- Creditor Name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NAMA KREDITUR"
        android:textColor="@color/text_hint"
        android:textSize="9sp"
        android:letterSpacing="0.15"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etCreditorName"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:hint="contoh: Bu Sari, Bank BCA"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:inputType="textPersonName|textCapWords"
        android:background="@android:color/transparent"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="16dp" />

    <!-- Amount -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NOMINAL HUTANG"
        android:textColor="@color/text_hint"
        android:textSize="9sp"
        android:letterSpacing="0.15"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etDebtAmount"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="0"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/negative"
        android:textSize="22sp"
        android:fontFamily="sans-serif-light"
        android:inputType="numberDecimal"
        android:background="@android:color/transparent"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KETERANGAN"
        android:textColor="@color/text_hint"
        android:textSize="9sp"
        android:letterSpacing="0.15"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etDebtDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Untuk apa, kapan jatuh tempo, dll (opsional)"
        android:textColorHint="@color/text_hint"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:inputType="textMultiLine"
        android:minLines="2"
        android:gravity="top"
        android:background="@android:color/transparent"
        android:layout_marginBottom="24dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="16dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/btnDebtCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Batal"
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnDebtSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Simpan"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
